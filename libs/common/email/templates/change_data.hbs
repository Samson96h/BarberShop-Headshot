<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Role Updated</title>
</head>

<body style="
  margin: 0;
  padding: 0;
  background: #f4f6f8;
  font-family: Arial, sans-serif;
">

  <div style="
    max-width: 520px;
    margin: 50px auto;
    padding: 32px;
    background: #ffffff;
    border-radius: 16px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
    text-align: center;
  ">

    <h2 style="
      margin: 0 0 16px;
      color: #222222;
      font-size: 28px;
    ">
      Hello, {{role}} 👋
    </h2>

    <p style="
      margin: 0;
      font-size: 16px;
      color: #555555;
      line-height: 1.6;
    ">
      Your role has been successfully changed.
    </p>

    <div style="margin-top: 28px;">
      <span style="
        display: inline-block;
        padding: 12px 20px;
        background: #4f46e5;
        color: #ffffff;
        border-radius: 8px;
        font-size: 14px;
        font-weight: bold;
        letter-spacing: 0.5px;
      ">
        Updated Successfully
      </span>
    </div>

  </div>

</body>

</html>